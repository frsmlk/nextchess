{
  "manifest_version": 3,
  "name": "NextChess",
  "version": "1.0.0",
  "description": "Visualize engine lines on the chess.com analysis board",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/analysis/*",
        "https://www.chess.com/game/review/*",
        "https://www.chess.com/analysis"
      ],
      "js": [
        "content/chess-utils.js",
        "content/dom-reader.js",
        "content/preview-board.js",
        "content/board-overlay.js",
        "content/content.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
